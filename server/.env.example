# Copia este archivo como .env
# Cadena de conexión de tu base de datos Postgres en Supabase.
# Usa el "Transaction pooler" (puerto 6543): Project Settings → Database → Connection string.
DATABASE_URL=

# Secreto para firmar los tokens JWT — genera uno único, ej. con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Opcional: API key de AviationStack (https://aviationstack.com) para
# autocompletar aerolínea y horarios al agregar un vuelo por su número.
# Sin esta variable, el botón "Buscar vuelo" simplemente no aparece.
FLIGHT_API_KEY=

# Opcional: notificaciones push (Web Push / VAPID). Genera tu propio par de
# claves una sola vez (no requiere cuenta externa ni costo):
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-correo@ejemplo.com

# Opcional: protege /api/cron/trip-reminders para que solo Vercel Cron
# (o tú manualmente) pueda dispararlo. Genera cualquier cadena aleatoria.
CRON_SECRET=
