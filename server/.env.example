# Copia este archivo como .env
# Cadena de conexión de tu base de datos Postgres en Supabase.
# Usa el "Transaction pooler" (puerto 6543): Project Settings → Database → Connection string.
DATABASE_URL=

# Secreto para firmar los tokens JWT — genera uno único, ej. con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
